# Copy to .env — NEVER commit .env to git

# ── Visual retrieval model ───────────────────────────────────────────────────
# "colqwen2.5" → best accuracy, needs a GPU (~16GB VRAM)
# "colsmol"    → CPU-friendly 500M params, good for dev
COLPALI_MODEL=colsmol
COLQWEN_MODEL_ID=vidore/colqwen2.5-v0.2
COLSMOL_MODEL_ID=vidore/colsmolvlm-v0.1

# ── Answer generation (VLM) ──────────────────────────────────────────────────
# ANSWERER_MODE: "api" (hosted vision model) or "local" (Qwen2-VL on GPU)
ANSWERER_MODE=api
# ANSWER_PROVIDER for api mode: "groq" (default, free) or "openai"
ANSWER_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY=your_openai_key_here        # only if ANSWER_PROVIDER=openai
QWEN_VL_MODEL_ID=Qwen/Qwen2-VL-7B-Instruct   # used when ANSWERER_MODE=local

# ── Hosted demo ──────────────────────────────────────────────────────────────
# Set DEMO_MODE=true on Streamlit Cloud to run the scripted, model-free demo.
DEMO_MODE=

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vision_rag_pages

# ── Observability (optional, self-hosted via docker-compose) ─────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Performance ──────────────────────────────────────────────────────────────
BATCH_SIZE=4           # pages per ColQwen batch (reduce if OOM)
PDF_DPI=150            # render DPI (150 default; 200 for fidelity)
TOP_K_PREFETCH=20      # stage 1: candidates to prefetch
TOP_K_RERANK=5         # stage 2: pages kept after MaxSim rerank
MAX_PAGES_PER_PDF=200
